# ---------------------------------------------------------------------------
# rankyourpolitician.com - environment variables
# Copy to `.env.local` (for the web app) and fill in. NONE are required to run
# the site locally: with no Firebase creds it reads the local seed JSON in
# /data/seed. Add these when you deploy to Vercel / wire up real services.
# ---------------------------------------------------------------------------

# --- Firebase (server-side, Admin SDK) --------------------------------------
# The web app reads Firestore with the Admin SDK. Provide the service-account
# JSON as a single-line string (recommended for Vercel) OR a file path locally.
# Get it: Firebase console -> Project settings -> Service accounts -> Generate key
FIREBASE_PROJECT_ID=
# Paste the whole JSON on one line (escape newlines in the private key as \n):
FIREBASE_SERVICE_ACCOUNT_JSON=
# ...or, locally only, point at a file that stays on your machine:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# --- Cloudflare Turnstile (bot gate for voting) -----------------------------
# https://dash.cloudflare.com/?to=/:account/turnstile  (free, unlimited)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Upstash Redis (vote rate-limiting + hot counters) ----------------------
# https://console.upstash.com  (free tier). REST creds:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Vote integrity ---------------------------------------------------------
# Server-side secret used to salt hashed IP+fingerprint. Rotate periodically.
# Generate: `openssl rand -hex 32`
VOTE_HASH_SALT=dev-only-change-me

# --- On-demand ISR revalidation ----------------------------------------------
# Shared secret for POST /api/revalidate: `npm run dm -- publish` calls it so a
# data publish appears on the next visit instead of the next daily rebuild.
# Set the SAME value in Vercel (the endpoint stays disabled while unset).
# Generate: `openssl rand -hex 32`
REVALIDATE_SECRET=
# Deployed origin the data manager pings after a publish (local .env.local
# only). Use the CANONICAL host - a host redirect (e.g. apex -> www) makes
# Node fetch drop the Authorization header, so the ping silently 401s:
REVALIDATE_URL=https://www.rankyourpolitician.com

# --- Google AdSense (leave blank until approved) ----------------------------
# When set, a single non-intrusive in-content ad renders. Blank = no ads.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=

# --- Grievance contact (IT Rules 2021) -------------------------------------
# The monitored mailbox shown on /grievance. MUST be a real address someone
# reads: the rules require a 24h acknowledgement. Leave blank to use the
# default in app/grievance/page.tsx.
NEXT_PUBLIC_GRIEVANCE_EMAIL=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
