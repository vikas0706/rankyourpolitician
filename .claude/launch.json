      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "autoPort": true
    },
    {
      "name": "prod-3101",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start", "--", "-p", "3101"],
      "port": 3101
    }
  ]
