# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
# isolated build output when NEXT_DIST_DIR is set (see next.config.mjs)
/.next-*/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env & secrets  — NEVER commit these
.env
.env*.local
.env.local
# Firebase service-account key lives ONLY on the local machine (data manager)
**/service-account*.json
**/serviceAccountKey*.json
/tools/data-manager/.secrets/
firebase-service-account.json

# local staging data produced by the data manager (may contain unpublished drafts)
/data/staging/

# typescript
*.tsbuildinfo

# vercel
.vercel

# Scratch fetches from the data-manager / debugging (curl dumps of source sites).
# Data belongs in data/seed/*.json with its citation — never a raw page copy.
/*.html

# Data-manager scrape caches (re-fetchable; keeps reruns off the source sites).
/tools/data-manager/.cache/
