","party":"Aam Aadmi Party","sub":"Bhadaur"},{"id":"dhuri-ac-pb-bhagwant-mann","name":"Bhagwant Mann","party":"Aam Aadmi Party","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Bhagwant%20Mann.png?width=400","sub":"Dhuri"},{"id":"dirba-ac-pb-harpal-singh-cheema","name":"Harpal Singh Cheema","party":"Aam Aadmi Party","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/H.%20S.%20Cheema.png?width=400","sub":"Dirba"},{"id":"malerkotla-ac-pb-mohammad-jamil-ur-rehman","name":"Mohammad Jamil Ur Rehman","party":"Aam Aadmi Party","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Dr.M.J.Rahman.jpg?width=400","sub":"Malerkotla"},{"id":"mehal-kalan-ac-pb-kulwant-singh-pandori","name":"Kulwant Singh Pandori","party":"Aam Aadmi Party","sub":"Mehal Kalan"},{"id":"sangrur-ac-pb-narinder-kaur-bharaj","name":"Narinder Kaur Bharaj","party":"Aam Aadmi Party","sub":"Sangrur"},{"id":"sunam-ac-pb-aman-arora","name":"Aman Arora","party":"Aam Aadmi Party","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Aman%20Arora.png?width=400","sub":"Sunam"}],"mps":[{"id":"patiala-dharamvir-gandhi","name":"Dharamvir Gandhi","party":"Indian National Congress","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Dharamvir%20Gandhi.png?width=400","sub":"Patiala"},{"id":"sangrur-gurmeet-singh-meet-hayer","name":"Gurmeet Singh Meet Hayer","party":"Aam Aadmi Party","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Meet%20Hayer%20L1.jpg?width=400","sub":"Sangrur"}],"portal":{"url":"https://sangrur.nic.in","whosWhoUrl":"https://sangrur.nic.in/whos-who/","contactUrl":"https://sangrur.nic.in/key-contacts/","phone":"01672234004","retrieved":"2026-07-15"}}},"channels":[{"kind":"phone","topic":"grievance","label":"Punjab CM Helpline / Citizen Grievance Helpline","value":"1100","scope":"state","source_url":"https://punjab.gov.in/contact-us/","source_name":"Government of Punjab - Contact Us (punjab.gov.in)","retrieved_date":"2026-07-15","note":"Published as \"Helpline Number: 1100\" on the official Government of Punjab Contact Us page. Feeds the state Public Grievance Redressal System (PGRS); the page directs grievances to connect.punjab.gov.in."},{"kind":"url","topic":"grievance","label":"Connect Punjab - Public Grievance Redressal System (PGRS)","value":"https://connect.punjab.gov.in/","scope":"state","source_url":"https://punjab.gov.in/notifications/this-portal-aims-to-provide-an-accessible-transparent-robust-effective-and-time-bound-public-grievance-redressal-system-pgrs-for-citizens-of-punjab/","source_name":"Government of Punjab - PGRS portal notification (punjab.gov.in)","retrieved_date":"2026-07-15","note":"Official Punjab online grievance portal. Confirmed by a punjab.gov.in notification announcing the PGRS portal, and the site itself resolves as \"Connect Punjab\"."},{"kind":"url","topic":"general","label":"Government of Punjab - Official State Portal","value":"https://punjab.gov.in/","scope":"state","source_url":"https://punjab.gov.in/","source_name":"Government of Punjab official portal (punjab.gov.in)","retrieved_date":"2026-07-15","note":"Official Government of Punjab (India) state portal homepage."},{"kind":"url","topic":"general","label":"District Portal of Punjab - directory of all 23 district websites","value":"https://punjab.s3waas.gov.in/","scope":"state","source_url":"https://punjab.s3waas.gov.in/","source_name":"District Portal of Punjab (punjab.s3waas.gov.in)","retrieved_date":"2026-07-15","note":"Official NIC/MeitY S3WaaS district portal for Punjab. Lists all 23 districts, each linking to its own site (e.g. ludhiana.nic.in, amritsar.nic.in, patiala.nic.in). Note: the punjab.gov.in \"Districts of Punjab\" page shows only a map image with no per-district links, so this is the real district directory."},{"kind":"url","topic":"police","label":"SAANJH - Punjab Police Online Citizen Services","value":"https://saanjh.punjabpolice.gov.in/","scope":"state","source_url":"https://saanjh.punjabpolice.gov.in/","source_name":"SAANJH - Punjab Police Online Citizen Services (punjabpolice.gov.in)","retrieved_date":"2026-07-15","note":"Official Punjab Police citizen services portal on the punjabpolice.gov.in domain."},{"kind":"phone","topic":"electricity","label":"PSPCL Electricity Complaint Helpline (Punjab State Power Corporation)","value":"1912","scope":"state","source_url":"https://pspcl.in/Customer-Care.aspx","source_name":"Punjab State Power Corporation Ltd (PSPCL) - Customer Care (pspcl.in)","retrieved_date":"2026-07-15","note":"Published as \"Customer Care Number: 1912\" on PSPCL's official site. PSPCL is Punjab's state electricity distribution utility. Complaint email: 1912@pspcl.in. SMS 'No Supply' to 1912 also works.","operator":"PSPCL"},{"kind":"phone","topic":"electricity","label":"PSPCL Missed-Call Supply Complaint Number","value":"18001801512","scope":"state","source_url":"https://www.pspcl.in/Otherlinks/nodal-complaint-center.aspx","source_name":"PSPCL - Nodal Complaint Centre (pspcl.in)","retrieved_date":"2026-07-15","note":"Published on PSPCL's official Nodal Complaint Centre page as the toll-free missed-call number for booking supply complaints. Same page lists PSPCL Central Control Room escalation numbers 96461-06835 / 96461-06836 if the division does not respond.","operator":"PSPCL"},{"kind":"url","topic":"electricity","label":"PSPCL Nodal Complaint Centre - division-wise complaint numbers","value":"https://www.pspcl.in/Otherlinks/nodal-complaint-center.aspx","scope":"state","source_url":"https://www.pspcl.in/Otherlinks/nodal-complaint-center.aspx","source_name":"PSPCL - Nodal Complaint Centre (pspcl.in)","retrieved_date":"2026-07-15","note":"Official PSPCL page listing Nodal Complaint Centre (NCC) numbers by circle and zone across Punjab, plus central escalation contacts.","operator":"PSPCL"},{"kind":"phone","topic":"emergency","label":"National Emergency Number (ERSS) - Police, Fire & Rescue, Health","value":"112","scope":"national","source_url":"https://www.mha.gov.in/en/commoncontent/emergency-response-support-system-erss","source_name":"Ministry of Home Affairs, Government of India","retrieved_date":"2026-07-15","note":"MHA's single pan-India emergency number: 'ONE INDIA ONE EMERGENCY NUMBER 112', a nationwide unified emergency response system. Works in every State/UT. Corroborated by india.gov.in helpline directory, which lists 112 as the Integrated Helpline (ERSS) covering Police, Fire & Rescue and Health services."},{"kind":"phone","topic":"fire","label":"Fire Helpline","value":"101","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed under 'Emergency Numbers' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"ambulance","label":"National Ambulance Service (NAS)","value":"102","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Ambulance Service (NAS)' under Emergency Numbers on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"women","label":"Women Helpline (national, toll-free)","value":"181","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Women Helpline Toll free No. - 181' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed on india.gov.in as both 'Women Helpline Number' and 'Domestic Violence Helpline'."},{"kind":"phone","topic":"women","label":"National Commission for Women (NCW) 24x7 Helpline","value":"14490","scope":"national","source_url":"https://ncw.gov.in/","source_name":"National Commission for Women (NCW)","retrieved_date":"2026-07-15","note":"NCW's own site states: 'Call the 24x7 NCW helpline at 14490 for immediate assistance and support', and lists 'NCW Women Helpline (14490)' under its Complaint Redressal cells. IMPORTANT: the india.gov.in helpline directory still lists 7827170170 as the 'National Commission for Women Helpline' - that number appears nowhere on ncw.gov.in (not even in raw HTML), so it appears stale and was deliberately omitted in favour of the department's own current number."},{"kind":"phone","topic":"child","label":"Child Helpline (national, toll-free)","value":"1098","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Child Helpline Toll free No. - 1098' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed as 'Child Help Line' on india.gov.in."},{"kind":"phone","topic":"senior","label":"Elderline - National Helpline for Senior Citizens (NHSC)","value":"14567","scope":"national","source_url":"https://scw.dosje.gov.in/elderline","source_name":"Department of Social Justice & Empowerment, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Elder Helpline: 14567' on the Department of Social Justice & Empowerment's own Elderline site, which the ministry homepage links to as the 'National Helpline for Senior Citizens (NHSC)'. india.gov.in additionally lists a landline 011-20893999 alongside 14567 for the Senior Citizens Helpline."},{"kind":"phone","topic":"grievance","label":"National Consumer Helpline (NCH)","value":"1915","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Consumer Helpline (NCH)' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026). Note: the NCH portal consumerhelpline.gov.in could not be reached at time of research (DNS resolves to an NIC address but the host refused connections / returned 504), so only the number is cited here - not the NCH portal URL."},{"kind":"phone","topic":"cyber","label":"Cyber Crime Helpline (online financial fraud reporting)","value":"1930","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Confirmed on the National Cyber Crime Reporting Portal homepage banner (MHA / Indian Cyber Crime Coordination Centre - I4C), which reads: 'To report online financial fraud, call 1930' and 'register your complaint at cybercrime.gov.in'. Independently corroborated by the india.gov.in helpline directory, which lists 1930 as the Cyber Crime Helpline."},{"kind":"url","topic":"cyber","label":"National Cyber Crime Reporting Portal (file a cybercrime complaint)","value":"https://cybercrime.gov.in/","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Verified live. Ministry of Home Affairs portal for reporting cybercrime; supports anonymous reporting, women/children-related crime, financial fraud and other cybercrime, plus complaint tracking. Nationwide."},{"kind":"url","topic":"grievance","label":"CPGRAMS - Centralised Public Grievance Redress and Monitoring System","value":"https://pgportal.gov.in/","scope":"national","source_url":"https://pgportal.gov.in/","source_name":"Ministry of Personnel, Public Grievances & Pensions, Government of India","retrieved_date":"2026-07-15","note":"Verified live; this is the citizen-facing portal. The site states CPGRAMS is 'an online platform available to the citizens 24x7 to lodge their grievances to the public authorities on any subject related to service delivery... a single portal connected to all the Ministries/Departments of Government of India and States.' Supports tracking by registration ID and an appeal facility. Note: it does not cover RTI matters, subjudice/court matters, or religious matters."},{"kind":"url","topic":"corruption","label":"Central Vigilance Commission - lodge a corruption complaint","value":"https://portal.cvc.gov.in/","scope":"national","source_url":"https://portal.cvc.gov.in/","source_name":"Central Vigilance Commission (CVC), Government of India","retrieved_date":"2026-07-15","note":"Verified live. CVC's Complaint Management System with a 'Citizen Login', complaint status tracking and a published complaint handling policy. Linked from cvc.gov.in as 'Lodge a complaint'. Covers corruption complaints against central government organisations."},{"kind":"phone","topic":"disaster","label":"Relief Commissioner for Natural Calamities","value":"1070","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"road","label":"Road Accident Helpline","value":"1073","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."}]}