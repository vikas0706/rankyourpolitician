":"https://vellore.nic.in/about-district/whos-who/","contactUrl":"https://vellore.nic.in/contact-directory/","phone":"04162252345","retrieved":"2026-07-15"}},"Viluppuram":{"officials":[],"mlas":[],"mps":[{"id":"arani-m-s-tharanivendhan","name":"M.S. Tharanivendhan","party":"Dravida Munnetra Kazhagam","sub":"Arani"},{"id":"kallakurichi-malaiyarasan-d","name":"Malaiyarasan D","party":"Dravida Munnetra Kazhagam","sub":"Kallakurichi"},{"id":"viluppuram-durai-ravikumar","name":"Durai Ravikumar","party":"Viduthalai Chiruthaigal Katchi","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Ravikumar%20D%20VCK%20Photo%2012022021%201200x800.jpg?width=400","sub":"Viluppuram"}],"portal":{"url":"https://viluppuram.nic.in","whosWhoUrl":"https://viluppuram.nic.in/about-district/whos-who/","contactUrl":"https://viluppuram.nic.in/home1/directory/contact-directory/","phone":"04146222470","retrieved":"2026-07-15"}},"Virudunagar":{"officials":[],"mlas":[],"mps":[{"id":"ramanathapuram-navas-kani","name":"Navas Kani","party":"Indian Union Muslim League","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Navaskani.jpg?width=400","sub":"Ramanathapuram"},{"id":"tenkasi-rani-srikumar","name":"Rani Srikumar","party":"Dravida Munnetra Kazhagam","sub":"Tenkasi"},{"id":"virudhunagar-manickam-tagore","name":"Manickam Tagore","party":"Indian National Congress","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Manickam%20Tagore.jpeg?width=400","sub":"Virudhunagar"}],"portal":{"url":"https://virudhunagar.nic.in","whosWhoUrl":"https://virudhunagar.nic.in/about-district/whos-who/","contactUrl":"https://virudhunagar.nic.in/contact-directory/","phone":"04562252348","retrieved":"2026-07-15"}}},"channels":[{"kind":"phone","topic":"grievance","label":"Tamil Nadu CM Helpline (Mudhalvarin Mugavari)","value":"1100","scope":"state","source_url":"https://cmhelpline.tnega.org/portal/en/kb/articles/tamil-nadu-cm-helpline-faqs","source_name":"Tamil Nadu CM Helpline portal (Tamil Nadu e-Governance Agency, TNeGA)","retrieved_date":"2026-07-15","note":"State grievance helpline, 7 AM - 10 PM, Monday-Sunday including government holidays. Operated under the Integrated and Inclusive Public Grievance CM Helpline Management System (IIPGCMS)."},{"kind":"url","topic":"grievance","label":"Tamil Nadu CM Helpline grievance portal (file/track grievances)","value":"https://cmhelpline.tnega.org/","scope":"state","source_url":"https://www.tn.gov.in/","source_name":"Tamil Nadu Government Portal (official state portal)","retrieved_date":"2026-07-15","note":"Linked as 'TN CM Helpline / Mudhalvarin Mugavari' from the official tn.gov.in homepage. The state Petition Processing Portal at gdp.tn.gov.in now 302-redirects here, confirming this is the current live state grievance portal. Domain is tnega.org (Tamil Nadu e-Governance Agency), not .gov.in."},{"kind":"url","topic":"grievance","label":"Tamil Nadu grievance portals directory (all departments)","value":"https://www.tn.gov.in/grievances.php","scope":"state","source_url":"https://www.tn.gov.in/grievances.php","source_name":"Tamil Nadu Government Portal (official state portal)","retrieved_date":"2026-07-15","note":"Official index page linking department-wise grievance portals (water, electricity, human rights commission, civil supplies, CPGRAMS etc)."},{"kind":"phone","topic":"grievance","label":"Chief Minister in your Constituency","value":"04425672345","scope":"state","source_url":"https://www.tn.gov.in/help_desk.php","source_name":"Tamil Nadu Government Portal - Help Line Numbers","retrieved_date":"2026-07-15","note":"Published on the official TN help line page as 'Chief Minister in your Constituency'. This is a separate scheme from the 1100 CM Helpline."},{"kind":"url","topic":"general","label":"Tamil Nadu Government official state portal","value":"https://www.tn.gov.in/","scope":"state","source_url":"https://www.tn.gov.in/","source_name":"Tamil Nadu Government Portal (official state portal)","retrieved_date":"2026-07-15","note":"Official Government of Tamil Nadu portal. Content owned and maintained by Government of Tamil Nadu; developed by National Informatics Centre."},{"kind":"url","topic":"general","label":"Tamil Nadu districts directory (links to each district website)","value":"https://www.tn.gov.in/district_list.php","scope":"state","source_url":"https://www.tn.gov.in/district_list.php","source_name":"Tamil Nadu Government Portal - Districts","retrieved_date":"2026-07-15","note":"Official districts listing on the state portal; each district name links to that district's own NIC website. Verified live, lists districts including Ariyalur, Chennai, Coimbatore, Madurai, Salem, Vellore."},{"kind":"url","topic":"general","label":"Tamil Nadu district collectors directory (names, phone, email)","value":"https://www.tn.gov.in/district_collector.php","scope":"state","source_url":"https://www.tn.gov.in/district_collector.php","source_name":"Tamil Nadu Government Portal - District Collector","retrieved_date":"2026-07-15","note":"Official directory of all 38 district collectors with phone, fax and email, plus links to each district's full contact directory."},{"kind":"url","topic":"police","label":"Tamil Nadu Police Citizen Portal","value":"https://www.police.tn.gov.in/","scope":"state","source_url":"https://www.police.tn.gov.in/","source_name":"Tamil Nadu Police - Citizen Portal","retrieved_date":"2026-07-15","note":"Official TN Police citizen portal (online complaints, FIR/CSR status, lost document report). Page is a JavaScript application, so only the portal identity could be confirmed by fetch - no phone numbers are cited from it."},{"kind":"phone","topic":"police","label":"Police / Crime Reporting","value":"100","scope":"state","source_url":"https://www.tn.gov.in/help_desk.php","source_name":"Tamil Nadu Government Portal - Help Line Numbers","retrieved_date":"2026-07-15","note":"Published by the Government of Tamil Nadu as 'Crime Reporting'."},{"kind":"phone","topic":"electricity","label":"Electricity complaints - TANGEDCO","value":"1912","scope":"state","source_url":"https://www.tn.gov.in/help_desk.php","source_name":"Tamil Nadu Government Portal - Help Line Numbers","retrieved_date":"2026-07-15","note":"Published by the Government of Tamil Nadu as TANGEDCO helpline, Toll Free, 24x7.","operator":"TNPDCL (TANGEDCO)"},{"kind":"url","topic":"electricity","label":"Electricity Consumer Grievance Redressal Forum (TNPDCL/TANGEDCO) online portal","value":"https://www.tnebltd.gov.in/cgrfonline/","scope":"state","source_url":"https://www.tn.gov.in/grievances.php","source_name":"Tamil Nadu Government Portal - Grievances","retrieved_date":"2026-07-15","note":"Listed as the TANGEDCO grievance portal on the official TN grievances page; fetched and confirmed live as the TNPDCL Consumer Grievance Redressal Forum portal.","operator":"TNPDCL (TANGEDCO)"},{"kind":"phone","topic":"electricity","label":"Electricity Power Support Line (TNPDCL)","value":"9498794987","scope":"state","source_url":"https://www.tnebltd.gov.in/cgrfonline/","source_name":"TNPDCL/TANGEDCO Consumer Grievance Redressal Forum portal (tnebltd.gov.in)","retrieved_date":"2026-07-15","note":"Displayed as 'Power Support Line' on the official TNPDCL/TANGEDCO consumer grievance redressal portal.","operator":"TNPDCL (TANGEDCO)"},{"kind":"phone","topic":"ambulance","label":"Ambulance Services","value":"108","scope":"state","source_url":"https://www.tn.gov.in/help_desk.php","source_name":"Tamil Nadu Government Portal - Help Line Numbers","retrieved_date":"2026-07-15","note":"Published by the Government of Tamil Nadu as 'Ambulance Services'."},{"kind":"phone","topic":"disaster","label":"Disaster Management Help Line (District)","value":"1077","scope":"state","source_url":"https://www.tn.gov.in/help_desk.php","source_name":"Tamil Nadu Government Portal - Help Line Numbers","retrieved_date":"2026-07-15","note":"Tamil Nadu State Disaster Management Authority (TNSDMA) district-level helpline."},{"kind":"phone","topic":"grievance","label":"Greater Chennai Corporation complaints (Chennai city only)","value":"1913","scope":"state","source_url":"https://www.tn.gov.in/help_desk.php","source_name":"Tamil Nadu Government Portal - Help Line Numbers","retrieved_date":"2026-07-15","note":"Toll Free, 24x7. City-level (Chennai), not statewide."},{"kind":"phone","topic":"water","label":"Chennai MetroWater complaints (Chennai city only)","value":"04445674567","scope":"state","source_url":"https://www.tn.gov.in/help_desk.php","source_name":"Tamil Nadu Government Portal - Help Line Numbers","retrieved_date":"2026-07-15","note":"24x7. City-level (Chennai Metropolitan Water Supply and Sewerage Board), not statewide."},{"kind":"phone","topic":"emergency","label":"National Emergency Number (ERSS) - Police, Fire & Rescue, Health","value":"112","scope":"national","source_url":"https://www.mha.gov.in/en/commoncontent/emergency-response-support-system-erss","source_name":"Ministry of Home Affairs, Government of India","retrieved_date":"2026-07-15","note":"MHA's single pan-India emergency number: 'ONE INDIA ONE EMERGENCY NUMBER 112', a nationwide unified emergency response system. Works in every State/UT. Corroborated by india.gov.in helpline directory, which lists 112 as the Integrated Helpline (ERSS) covering Police, Fire & Rescue and Health services."},{"kind":"phone","topic":"fire","label":"Fire Helpline","value":"101","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed under 'Emergency Numbers' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"ambulance","label":"National Ambulance Service (NAS)","value":"102","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Ambulance Service (NAS)' under Emergency Numbers on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"women","label":"Women Helpline (national, toll-free)","value":"181","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Women Helpline Toll free No. - 181' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed on india.gov.in as both 'Women Helpline Number' and 'Domestic Violence Helpline'."},{"kind":"phone","topic":"women","label":"National Commission for Women (NCW) 24x7 Helpline","value":"14490","scope":"national","source_url":"https://ncw.gov.in/","source_name":"National Commission for Women (NCW)","retrieved_date":"2026-07-15","note":"NCW's own site states: 'Call the 24x7 NCW helpline at 14490 for immediate assistance and support', and lists 'NCW Women Helpline (14490)' under its Complaint Redressal cells. IMPORTANT: the india.gov.in helpline directory still lists 7827170170 as the 'National Commission for Women Helpline' - that number appears nowhere on ncw.gov.in (not even in raw HTML), so it appears stale and was deliberately omitted in favour of the department's own current number."},{"kind":"phone","topic":"child","label":"Child Helpline (national, toll-free)","value":"1098","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Child Helpline Toll free No. - 1098' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed as 'Child Help Line' on india.gov.in."},{"kind":"phone","topic":"senior","label":"Elderline - National Helpline for Senior Citizens (NHSC)","value":"14567","scope":"national","source_url":"https://scw.dosje.gov.in/elderline","source_name":"Department of Social Justice & Empowerment, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Elder Helpline: 14567' on the Department of Social Justice & Empowerment's own Elderline site, which the ministry homepage links to as the 'National Helpline for Senior Citizens (NHSC)'. india.gov.in additionally lists a landline 011-20893999 alongside 14567 for the Senior Citizens Helpline."},{"kind":"phone","topic":"grievance","label":"National Consumer Helpline (NCH)","value":"1915","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Consumer Helpline (NCH)' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026). Note: the NCH portal consumerhelpline.gov.in could not be reached at time of research (DNS resolves to an NIC address but the host refused connections / returned 504), so only the number is cited here - not the NCH portal URL."},{"kind":"phone","topic":"cyber","label":"Cyber Crime Helpline (online financial fraud reporting)","value":"1930","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Confirmed on the National Cyber Crime Reporting Portal homepage banner (MHA / Indian Cyber Crime Coordination Centre - I4C), which reads: 'To report online financial fraud, call 1930' and 'register your complaint at cybercrime.gov.in'. Independently corroborated by the india.gov.in helpline directory, which lists 1930 as the Cyber Crime Helpline."},{"kind":"url","topic":"cyber","label":"National Cyber Crime Reporting Portal (file a cybercrime complaint)","value":"https://cybercrime.gov.in/","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Verified live. Ministry of Home Affairs portal for reporting cybercrime; supports anonymous reporting, women/children-related crime, financial fraud and other cybercrime, plus complaint tracking. Nationwide."},{"kind":"url","topic":"grievance","label":"CPGRAMS - Centralised Public Grievance Redress and Monitoring System","value":"https://pgportal.gov.in/","scope":"national","source_url":"https://pgportal.gov.in/","source_name":"Ministry of Personnel, Public Grievances & Pensions, Government of India","retrieved_date":"2026-07-15","note":"Verified live; this is the citizen-facing portal. The site states CPGRAMS is 'an online platform available to the citizens 24x7 to lodge their grievances to the public authorities on any subject related to service delivery... a single portal connected to all the Ministries/Departments of Government of India and States.' Supports tracking by registration ID and an appeal facility. Note: it does not cover RTI matters, subjudice/court matters, or religious matters."},{"kind":"url","topic":"corruption","label":"Central Vigilance Commission - lodge a corruption complaint","value":"https://portal.cvc.gov.in/","scope":"national","source_url":"https://portal.cvc.gov.in/","source_name":"Central Vigilance Commission (CVC), Government of India","retrieved_date":"2026-07-15","note":"Verified live. CVC's Complaint Management System with a 'Citizen Login', complaint status tracking and a published complaint handling policy. Linked from cvc.gov.in as 'Lodge a complaint'. Covers corruption complaints against central government organisations."},{"kind":"phone","topic":"disaster","label":"Relief Commissioner for Natural Calamities","value":"1070","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"road","label":"Road Accident Helpline","value":"1073","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."}]}