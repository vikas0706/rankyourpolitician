sm%20of%20schemes%20of%20Ministry%20of%20Tribal%20Affairs%20for%20development%20of%20Tribals%2C%20in%20New%20Delhi%20on%20August%2005%2C%202014.jpg?width=400","sub":"Bharuch"},{"id":"chhota-udaipur-jashubhai-rathva","name":"Jashubhai Rathva","party":"Bharatiya Janata Party","sub":"Chhota Udaipur"},{"id":"vadodara-hemang-joshi","name":"Hemang Joshi","party":"Bharatiya Janata Party","sub":"Vadodara"}],"portal":{"url":"https://vadodara.gujarat.gov.in","contactUrl":"https://vadodara.gujarat.gov.in/showpage.aspx?contentid=20","retrieved":"2026-07-15"}},"Valsad":{"officials":[],"mlas":[],"mps":[{"id":"valsad-dhavalbhai-patel","name":"Dhavalbhai Patel","party":"Bharatiya Janata Party","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/DhavalBhaiPatel.jpg?width=400","sub":"Valsad"}],"portal":{"url":"https://valsad.nic.in","whosWhoUrl":"https://valsad.nic.in/about-district/whos-who/","contactUrl":"https://valsad.nic.in/helpline/","phone":"02632253613","retrieved":"2026-07-15"}}},"channels":[{"kind":"phone","topic":"police","label":"Police control room","value":"100","scope":"state","source_url":"https://gujhome.gujarat.gov.in/portal/web?requestType=ApplicationRH&actionVal=showCenterContent&screenId=115&targetPage=helpLineNo","source_name":"Gujarat Police Citizen Portal - Helpline Numbers (Home Department, Govt. of Gujarat)","retrieved_date":"2026-07-15","note":"Listed by Gujarat Police as \"Police Helpline - 100/112\"."},{"kind":"url","topic":"police","label":"Gujarat Police Citizen Portal (e-FIR, complaints, verifications)","value":"https://gujhome.gujarat.gov.in/portal/","scope":"state","source_url":"https://police.gujarat.gov.in/","source_name":"Office of the Director General of Police, Gujarat State","retrieved_date":"2026-07-15","note":"Official citizen services portal of the Home Department. Linked as \"Citizen Portal\" from the DGP Gujarat website. fir.gujarat.gov.in now redirects here."},{"kind":"url","topic":"police","label":"Director General of Police, Gujarat - official website","value":"https://police.gujarat.gov.in/","scope":"state","source_url":"https://police.gujarat.gov.in/","source_name":"Office of the Director General of Police, Gujarat State","retrieved_date":"2026-07-15","note":"State police headquarters site; hosts safety advisories, forms and links to citizen services."},{"kind":"phone","topic":"road","label":"Traffic problems / road accident helpline (Gujarat Police)","value":"18002331122","scope":"state","source_url":"https://gujhome.gujarat.gov.in/portal/web?requestType=ApplicationRH&actionVal=showCenterContent&screenId=115&targetPage=helpLineNo","source_name":"Gujarat Police Citizen Portal - Helpline Numbers (Home Department, Govt. of Gujarat)","retrieved_date":"2026-07-15","note":"Gujarat-specific toll-free traffic grievance line; email trafficgrievance@gujarat.gov.in."},{"kind":"phone","topic":"ambulance","label":"Ambulance (108 Emergency Service)","value":"108","scope":"state","source_url":"https://gujhome.gujarat.gov.in/portal/web?requestType=ApplicationRH&actionVal=showCenterContent&screenId=115&targetPage=helpLineNo","source_name":"Gujarat Police Citizen Portal - Helpline Numbers (Home Department, Govt. of Gujarat)","retrieved_date":"2026-07-15"},{"kind":"phone","topic":"grievance","label":"CM Helpline - grievance number (WhatsApp)","value":"7030930344","scope":"state","source_url":"https://swagat.gujarat.gov.in/","source_name":"SWAGAT Online - Public Grievance Redressal, Govt. of Gujarat","retrieved_date":"2026-07-15","note":"Labelled on the SWAGAT portal as \"CM Helpline grievance number\". It is a WhatsApp chatbot for filing grievances with the CMO, not a voice short code - Gujarat does not publish a 3-4 digit CM helpline. Also published as https://wa.me/917030930344 on the CMO site."},{"kind":"url","topic":"grievance","label":"SWAGAT Online - state public grievance redressal portal","value":"https://swagat.gujarat.gov.in/","scope":"state","source_url":"https://swagat.gujarat.gov.in/","source_name":"SWAGAT Online - Public Grievance Redressal, Govt. of Gujarat","retrieved_date":"2026-07-15","note":"\"State Wide Attention on Grievances by Application of Technology\". Gujarat's flagship grievance system, with Gram, Taluka, Jilla and Rajya (CM-level) SWAGAT tiers. Citizens can file online and track status by mobile number."},{"kind":"url","topic":"grievance","label":"Write to CMO Gujarat - grievances, suggestions, appointments","value":"https://cmogujarat.gov.in/en/write-to-cmo","scope":"state","source_url":"https://cmogujarat.gov.in/en/write-to-cmo","source_name":"Chief Minister's Office, Govt. of Gujarat","retrieved_date":"2026-07-15"},{"kind":"phone","topic":"grievance","label":"CMO Gujarat - Jansampark (public liaison) unit","value":"07923250072","scope":"state","source_url":"https://swagat.gujarat.gov.in/cmog/Home/contactus.html","source_name":"SWAGAT Online - Contact Us, Govt. of Gujarat","retrieved_date":"2026-07-15","note":"Jansampark Unit, Ground floor, Swarnim Sankul-2, New Sachivalay, Sector 10, Gandhinagar - the contact published for SWAGAT grievances."},{"kind":"phone","topic":"general","label":"Chief Minister's Office, Gujarat","value":"07923250073","scope":"state","source_url":"https://cmogujarat.gov.in/en/contact-us/","source_name":"Chief Minister's Office, Govt. of Gujarat - Contact Us","retrieved_date":"2026-07-15","note":"CMO office line (alternate: 07923250074). 3rd floor, Swarnim Sankul-1, New Sachivalay, Sector 10, Gandhinagar."},{"kind":"url","topic":"general","label":"Gujarat State Portal - official state government homepage","value":"https://gujaratindia.gov.in/","scope":"state","source_url":"https://gujaratindia.gov.in/","source_name":"Gujarat State Portal, Govt. of Gujarat","retrieved_date":"2026-07-15","note":"Unified interface to all Government of Gujarat departments. Page footer showed \"Last Updated: 14/07/2026\" when checked."},{"kind":"url","topic":"general","label":"Districts of Gujarat - district website directory","value":"https://gujarat.s3waas.gov.in/","scope":"state","source_url":"https://gujarat.s3waas.gov.in/","source_name":"Gujarat District Portal (S3WaaS, NIC / Govt. of Gujarat)","retrieved_date":"2026-07-15","note":"Official district portal listing links to all 33 district websites (Ahmedabad, Amreli, Anand, Aravalli, Banaskantha, Bharuch, Bhavnagar, Botad, Chhota Udepur, Dahod, Devbhumi Dwarka, Gandhinagar, Gir Somnath, Jamnagar, Junagadh, Kachchh, Kheda, Mahesana, Mahisagar, Morbi, Narmada, Navsari, Panchmahals, Patan, Porbandar, Rajkot, Sabarkantha, Surat, Surendranagar, Tapi, Dang, Vadodara, Valsad), in English and Gujarati."},{"kind":"url","topic":"electricity","label":"Gujarat electricity helplines - Energy & Petrochemicals Department","value":"https://guj-epd.gujarat.gov.in/Home/HelpLine","scope":"state","source_url":"https://guj-epd.gujarat.gov.in/Home/HelpLine","source_name":"Energy & Petrochemicals Department, Govt. of Gujarat - Helpline","retrieved_date":"2026-07-15","note":"The state's central page listing consumer helplines for all four government DISCOMs. Gujarat does NOT publish a single statewide electricity number - the number depends on your DISCOM.","operator":"All Gujarat DISCOMs (guj-epd helplines)"},{"kind":"phone","topic":"electricity","label":"PGVCL - Paschim Gujarat Vij Company (Saurashtra/Kutch) complaints","value":"19122","scope":"state","source_url":"https://guj-epd.gujarat.gov.in/Home/HelpLine","source_name":"Energy & Petrochemicals Department, Govt. of Gujarat - Helpline","retrieved_date":"2026-07-15","note":"Toll-free alternate: 1800233155333.","operator":"PGVCL","districts":["Amreli","Bhavnagar","Jamnagar","Junagadh","Kachchh","Porbandar","Rajkot","Surendranagar"]},{"kind":"email","topic":"electricity","label":"PGVCL support (online payment / consumer query)","value":"info.pgvcl@gebmail.com","scope":"state","operator":"PGVCL","districts":["Amreli","Bhavnagar","Jamnagar","Junagadh","Kachchh","Porbandar","Rajkot","Surendranagar"],"source_url":"https://www.pgvcl.com/about_us/contactus.php","source_name":"PGVCL official website - Contact Us","retrieved_date":"2026-07-16"},{"kind":"phone","topic":"electricity","label":"UGVCL - Uttar Gujarat Vij Company (North Gujarat) complaints","value":"19121","scope":"state","source_url":"https://guj-epd.gujarat.gov.in/Home/HelpLine","source_name":"Energy & Petrochemicals Department, Govt. of Gujarat - Helpline","retrieved_date":"2026-07-15","note":"Toll-free alternate: 1800233155335.","operator":"UGVCL","districts":["Ahmadabad","Anand","Banas Kantha","Gandhinagar","Kheda","Mahesana","Patan","Sabar Kantha","Surendranagar"]},{"kind":"email","topic":"electricity","label":"UGVCL Customer Care Center (consumer complaints)","value":"ccc@ugvcl.com","scope":"state","operator":"UGVCL","districts":["Ahmadabad","Anand","Banas Kantha","Gandhinagar","Kheda","Mahesana","Patan","Sabar Kantha","Surendranagar"],"source_url":"https://www.ugvcl.com/companyprofile","source_name":"UGVCL official website - Company Profile","retrieved_date":"2026-07-16"},{"kind":"phone","topic":"electricity","label":"MGVCL - Madhya Gujarat Vij Company (Central Gujarat) complaints","value":"19124","scope":"state","source_url":"https://guj-epd.gujarat.gov.in/Home/HelpLine","source_name":"Energy & Petrochemicals Department, Govt. of Gujarat - Helpline","retrieved_date":"2026-07-15","note":"Toll-free alternate: 18002332670.","operator":"MGVCL","districts":["Anand","Dohad","Kheda","Panch Mahals","Vadodara"]},{"kind":"email","topic":"electricity","label":"MGVCL customer support (general / e-payment)","value":"support.mgvcl@gebmail.com","scope":"state","operator":"MGVCL","districts":["Anand","Dohad","Kheda","Panch Mahals","Vadodara"],"source_url":"https://www.mgvcl.com/contact-us.php","source_name":"MGVCL official website - Contact Us","retrieved_date":"2026-07-16"},{"kind":"phone","topic":"electricity","label":"DGVCL - Dakshin Gujarat Vij Company (South Gujarat) complaints","value":"19123","scope":"state","source_url":"https://guj-epd.gujarat.gov.in/Home/HelpLine","source_name":"Energy & Petrochemicals Department, Govt. of Gujarat - Helpline","retrieved_date":"2026-07-15","note":"Toll-free alternate: 18002333003.","operator":"DGVCL","districts":["Bharuch","Narmada","Navsari","Surat","The Dangs","Valsad"]},{"kind":"email","topic":"electricity","label":"DGVCL corporate office contact email","value":"contactus@dgvcl.com","scope":"state","operator":"DGVCL","districts":["Bharuch","Narmada","Navsari","Surat","The Dangs","Valsad"],"source_url":"http://dgvcl.com/contact.php","source_name":"DGVCL official website - Contact Us","retrieved_date":"2026-07-16"},{"kind":"phone","topic":"electricity","label":"Torrent Power customer care - Ahmedabad, Gandhinagar & Surat","value":"9099991912","scope":"state","source_url":"https://www.torrentpower.com/index.php/site/info/contactus_dist","source_name":"Torrent Power Ltd - Distribution contact page (official site)","retrieved_date":"2026-07-16","note":"Torrent Power (not the four state Vij companies) is the distribution licensee in Ahmedabad, Gandhinagar, Surat, Dahej SEZ and Dholera SIR. +91 90 9999 1912 is printed for both Ahmedabad/Gandhinagar and Surat on the official contact page.","operator":"Torrent Power","districts":["Ahmadabad","Gandhinagar","Surat"]},{"kind":"phone","topic":"emergency","label":"National Emergency Number (ERSS) - Police, Fire & Rescue, Health","value":"112","scope":"national","source_url":"https://www.mha.gov.in/en/commoncontent/emergency-response-support-system-erss","source_name":"Ministry of Home Affairs, Government of India","retrieved_date":"2026-07-15","note":"MHA's single pan-India emergency number: 'ONE INDIA ONE EMERGENCY NUMBER 112', a nationwide unified emergency response system. Works in every State/UT. Corroborated by india.gov.in helpline directory, which lists 112 as the Integrated Helpline (ERSS) covering Police, Fire & Rescue and Health services."},{"kind":"phone","topic":"fire","label":"Fire Helpline","value":"101","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed under 'Emergency Numbers' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"ambulance","label":"National Ambulance Service (NAS)","value":"102","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Ambulance Service (NAS)' under Emergency Numbers on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"women","label":"Women Helpline (national, toll-free)","value":"181","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Women Helpline Toll free No. - 181' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed on india.gov.in as both 'Women Helpline Number' and 'Domestic Violence Helpline'."},{"kind":"phone","topic":"women","label":"National Commission for Women (NCW) 24x7 Helpline","value":"14490","scope":"national","source_url":"https://ncw.gov.in/","source_name":"National Commission for Women (NCW)","retrieved_date":"2026-07-15","note":"NCW's own site states: 'Call the 24x7 NCW helpline at 14490 for immediate assistance and support', and lists 'NCW Women Helpline (14490)' under its Complaint Redressal cells. IMPORTANT: the india.gov.in helpline directory still lists 7827170170 as the 'National Commission for Women Helpline' - that number appears nowhere on ncw.gov.in (not even in raw HTML), so it appears stale and was deliberately omitted in favour of the department's own current number."},{"kind":"phone","topic":"child","label":"Child Helpline (national, toll-free)","value":"1098","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Child Helpline Toll free No. - 1098' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed as 'Child Help Line' on india.gov.in."},{"kind":"phone","topic":"senior","label":"Elderline - National Helpline for Senior Citizens (NHSC)","value":"14567","scope":"national","source_url":"https://scw.dosje.gov.in/elderline","source_name":"Department of Social Justice & Empowerment, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Elder Helpline: 14567' on the Department of Social Justice & Empowerment's own Elderline site, which the ministry homepage links to as the 'National Helpline for Senior Citizens (NHSC)'. india.gov.in additionally lists a landline 011-20893999 alongside 14567 for the Senior Citizens Helpline."},{"kind":"phone","topic":"grievance","label":"National Consumer Helpline (NCH)","value":"1915","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Consumer Helpline (NCH)' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026). Note: the NCH portal consumerhelpline.gov.in could not be reached at time of research (DNS resolves to an NIC address but the host refused connections / returned 504), so only the number is cited here - not the NCH portal URL."},{"kind":"phone","topic":"cyber","label":"Cyber Crime Helpline (online financial fraud reporting)","value":"1930","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Confirmed on the National Cyber Crime Reporting Portal homepage banner (MHA / Indian Cyber Crime Coordination Centre - I4C), which reads: 'To report online financial fraud, call 1930' and 'register your complaint at cybercrime.gov.in'. Independently corroborated by the india.gov.in helpline directory, which lists 1930 as the Cyber Crime Helpline."},{"kind":"url","topic":"cyber","label":"National Cyber Crime Reporting Portal (file a cybercrime complaint)","value":"https://cybercrime.gov.in/","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Verified live. Ministry of Home Affairs portal for reporting cybercrime; supports anonymous reporting, women/children-related crime, financial fraud and other cybercrime, plus complaint tracking. Nationwide."},{"kind":"url","topic":"grievance","label":"CPGRAMS - Centralised Public Grievance Redress and Monitoring System","value":"https://pgportal.gov.in/","scope":"national","source_url":"https://pgportal.gov.in/","source_name":"Ministry of Personnel, Public Grievances & Pensions, Government of India","retrieved_date":"2026-07-15","note":"Verified live; this is the citizen-facing portal. The site states CPGRAMS is 'an online platform available to the citizens 24x7 to lodge their grievances to the public authorities on any subject related to service delivery... a single portal connected to all the Ministries/Departments of Government of India and States.' Supports tracking by registration ID and an appeal facility. Note: it does not cover RTI matters, subjudice/court matters, or religious matters."},{"kind":"url","topic":"corruption","label":"Central Vigilance Commission - lodge a corruption complaint","value":"https://portal.cvc.gov.in/","scope":"national","source_url":"https://portal.cvc.gov.in/","source_name":"Central Vigilance Commission (CVC), Government of India","retrieved_date":"2026-07-15","note":"Verified live. CVC's Complaint Management System with a 'Citizen Login', complaint status tracking and a published complaint handling policy. Linked from cvc.gov.in as 'Lodge a complaint'. Covers corruption complaints against central government organisations."},{"kind":"phone","topic":"disaster","label":"Relief Commissioner for Natural Calamities","value":"1070","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"road","label":"Road Accident Helpline","value":"1073","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."}]}