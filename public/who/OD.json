e":"state","source_url":"https://odisha.gov.in/en","source_name":"Government of Odisha official portal","retrieved_date":"2026-07-15","note":"Official state portal homepage. Links to departments, district directory, emergency contacts and Jana Sunani."},{"kind":"url","topic":"general","label":"Odisha district directory - all 30 districts","value":"https://district.odisha.gov.in/","scope":"state","source_url":"http://district.odisha.gov.in/or","source_name":"Odisha District Portal (E&IT Dept / OCAC)","retrieved_date":"2026-07-15","note":"Official district listing linked from odisha.gov.in. Lists all 30 districts, each linking to its own <district>.odisha.gov.in site. Root URL 301-redirects to the Odia (/or) version."},{"kind":"url","topic":"grievance","label":"Jana Sunani - Odisha public grievance redressal portal","value":"https://janasunani.odisha.gov.in/","scope":"state","source_url":"https://janasunani.odisha.gov.in/","source_name":"Jana Sunani - Public Grievance Redressal Portal, Govt. of Odisha","retrieved_date":"2026-07-15","note":"Odisha's integrated public grievance redressal system, run by the Dept. of General Administration & Public Grievances under the Office of the Chief Minister. This is the state's CM grievance cell portal."},{"kind":"phone","topic":"grievance","label":"Jana Sunani grievance WhatsApp","value":"6370951930","scope":"state","source_url":"https://janasunani.odisha.gov.in/","source_name":"Jana Sunani - Public Grievance Redressal Portal, Govt. of Odisha","retrieved_date":"2026-07-15","note":"WhatsApp ONLY - not a voice helpline. Send 'Hi' to this number to register a grievance or check status."},{"kind":"phone","topic":"grievance","label":"Sanjog Helpline - Odisha citizen grievance/scheme helpline (short code)","value":"155335","scope":"state","source_url":"https://www.ocac.in/en/services/state-initiatives/sanjog-helpline","source_name":"Odisha Computer Application Centre (OCAC), Govt. of Odisha","retrieved_date":"2026-07-15","note":"Odisha's citizen grievance call centre, run by OCAC (state government agency). Used to register/track grievances and get information on Govt. of Odisha schemes. Confirmed on two separate OCAC pages."},{"kind":"phone","topic":"grievance","label":"Sanjog Helpline - Odisha citizen grievance/scheme helpline (toll-free)","value":"18003456770","scope":"state","source_url":"https://www.ocac.in/en/services/state-initiatives/sanjog-helpline","source_name":"Odisha Computer Application Centre (OCAC), Govt. of Odisha","retrieved_date":"2026-07-15","note":"Toll-free alternative to 155335 for the same Sanjog grievance call centre. Confirmed on two separate OCAC pages."},{"kind":"url","topic":"police","label":"Odisha Police Citizen Portal","value":"https://citizenportal-op.gov.in/","scope":"state","source_url":"https://citizenportal-op.gov.in/","source_name":"Odisha Police / State Crime Records Bureau, Home Dept., Govt. of Odisha","retrieved_date":"2026-07-15","note":"Official Odisha Police citizen e-services portal (complaint registration, FIR copy, lost property, missing person, character certificate, tenant/domestic-help verification)."},{"kind":"phone","topic":"police","label":"Police","value":"100","scope":"state","source_url":"https://odisha.gov.in/en/contacts/emergency","source_name":"Government of Odisha - Emergency Contacts","retrieved_date":"2026-07-15","note":"Police number as published on the official Odisha state portal emergency contacts page."},{"kind":"phone","topic":"ambulance","label":"Ambulance","value":"108","scope":"state","source_url":"https://odisha.gov.in/en/contacts/emergency","source_name":"Government of Odisha - Emergency Contacts","retrieved_date":"2026-07-15","note":"As published on the official Odisha state portal emergency contacts page. The same page also lists 102 for the Janani (maternal) ambulance."},{"kind":"phone","topic":"health","label":"Health helpline","value":"104","scope":"state","source_url":"https://odisha.gov.in/en/contacts/emergency","source_name":"Government of Odisha - Emergency Contacts","retrieved_date":"2026-07-15","note":"Listed on the state portal emergency page as the Odisha health/Covid helpline. Treat the Covid framing as dated; 104 remains the state health helpline short code."},{"kind":"phone","topic":"women","label":"Women helpline (police)","value":"1091","scope":"state","source_url":"https://odisha.gov.in/en/contacts/emergency","source_name":"Government of Odisha - Emergency Contacts","retrieved_date":"2026-07-15","note":"Listed alongside 181 as a women helpline on Odisha's official emergency contacts page. Standard national short code republished by the state."},{"kind":"phone","topic":"senior","label":"Senior citizen helpline","value":"1090","scope":"state","source_url":"https://odisha.gov.in/en/contacts/emergency","source_name":"Government of Odisha - Emergency Contacts","retrieved_date":"2026-07-15","note":"As published on the official Odisha state portal emergency contacts page."},{"kind":"phone","topic":"electricity","label":"Electricity complaint (all Odisha DISCOMs)","value":"1912","scope":"state","source_url":"https://www.tpnodl.com/customer-zone/complaints","source_name":"TP Northern Odisha Distribution Ltd (TPNODL) - official DISCOM site","retrieved_date":"2026-07-15","note":"Odisha has NO central state electricity complaint number - the Energy Department site publishes none. 1912 is the common complaint short code used by all four Odisha DISCOMs; independently confirmed on TPNODL's and TPSODL's own official sites. DISCOM-specific toll-free lines also exist (TPNODL 18003456718, TPSODL 18002026).","operator":"All Odisha discoms (TPCODL/TPWODL/TPSODL/TPNODL)"},{"kind":"phone","topic":"emergency","label":"National Emergency Number (ERSS) - Police, Fire & Rescue, Health","value":"112","scope":"national","source_url":"https://www.mha.gov.in/en/commoncontent/emergency-response-support-system-erss","source_name":"Ministry of Home Affairs, Government of India","retrieved_date":"2026-07-15","note":"MHA's single pan-India emergency number: 'ONE INDIA ONE EMERGENCY NUMBER 112', a nationwide unified emergency response system. Works in every State/UT. Corroborated by india.gov.in helpline directory, which lists 112 as the Integrated Helpline (ERSS) covering Police, Fire & Rescue and Health services."},{"kind":"phone","topic":"fire","label":"Fire Helpline","value":"101","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed under 'Emergency Numbers' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"ambulance","label":"National Ambulance Service (NAS)","value":"102","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Ambulance Service (NAS)' under Emergency Numbers on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"women","label":"Women Helpline (national, toll-free)","value":"181","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Women Helpline Toll free No. - 181' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed on india.gov.in as both 'Women Helpline Number' and 'Domestic Violence Helpline'."},{"kind":"phone","topic":"women","label":"National Commission for Women (NCW) 24x7 Helpline","value":"14490","scope":"national","source_url":"https://ncw.gov.in/","source_name":"National Commission for Women (NCW)","retrieved_date":"2026-07-15","note":"NCW's own site states: 'Call the 24x7 NCW helpline at 14490 for immediate assistance and support', and lists 'NCW Women Helpline (14490)' under its Complaint Redressal cells. IMPORTANT: the india.gov.in helpline directory still lists 7827170170 as the 'National Commission for Women Helpline' - that number appears nowhere on ncw.gov.in (not even in raw HTML), so it appears stale and was deliberately omitted in favour of the department's own current number."},{"kind":"phone","topic":"child","label":"Child Helpline (national, toll-free)","value":"1098","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Child Helpline Toll free No. - 1098' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed as 'Child Help Line' on india.gov.in."},{"kind":"phone","topic":"senior","label":"Elderline - National Helpline for Senior Citizens (NHSC)","value":"14567","scope":"national","source_url":"https://scw.dosje.gov.in/elderline","source_name":"Department of Social Justice & Empowerment, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Elder Helpline: 14567' on the Department of Social Justice & Empowerment's own Elderline site, which the ministry homepage links to as the 'National Helpline for Senior Citizens (NHSC)'. india.gov.in additionally lists a landline 011-20893999 alongside 14567 for the Senior Citizens Helpline."},{"kind":"phone","topic":"grievance","label":"National Consumer Helpline (NCH)","value":"1915","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Consumer Helpline (NCH)' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026). Note: the NCH portal consumerhelpline.gov.in could not be reached at time of research (DNS resolves to an NIC address but the host refused connections / returned 504), so only the number is cited here - not the NCH portal URL."},{"kind":"phone","topic":"cyber","label":"Cyber Crime Helpline (online financial fraud reporting)","value":"1930","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Confirmed on the National Cyber Crime Reporting Portal homepage banner (MHA / Indian Cyber Crime Coordination Centre - I4C), which reads: 'To report online financial fraud, call 1930' and 'register your complaint at cybercrime.gov.in'. Independently corroborated by the india.gov.in helpline directory, which lists 1930 as the Cyber Crime Helpline."},{"kind":"url","topic":"cyber","label":"National Cyber Crime Reporting Portal (file a cybercrime complaint)","value":"https://cybercrime.gov.in/","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Verified live. Ministry of Home Affairs portal for reporting cybercrime; supports anonymous reporting, women/children-related crime, financial fraud and other cybercrime, plus complaint tracking. Nationwide."},{"kind":"url","topic":"grievance","label":"CPGRAMS - Centralised Public Grievance Redress and Monitoring System","value":"https://pgportal.gov.in/","scope":"national","source_url":"https://pgportal.gov.in/","source_name":"Ministry of Personnel, Public Grievances & Pensions, Government of India","retrieved_date":"2026-07-15","note":"Verified live; this is the citizen-facing portal. The site states CPGRAMS is 'an online platform available to the citizens 24x7 to lodge their grievances to the public authorities on any subject related to service delivery... a single portal connected to all the Ministries/Departments of Government of India and States.' Supports tracking by registration ID and an appeal facility. Note: it does not cover RTI matters, subjudice/court matters, or religious matters."},{"kind":"url","topic":"corruption","label":"Central Vigilance Commission - lodge a corruption complaint","value":"https://portal.cvc.gov.in/","scope":"national","source_url":"https://portal.cvc.gov.in/","source_name":"Central Vigilance Commission (CVC), Government of India","retrieved_date":"2026-07-15","note":"Verified live. CVC's Complaint Management System with a 'Citizen Login', complaint status tracking and a published complaint handling policy. Linked from cvc.gov.in as 'Lodge a complaint'. Covers corruption complaints against central government organisations."},{"kind":"phone","topic":"disaster","label":"Relief Commissioner for Natural Calamities","value":"1070","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"road","label":"Road Accident Helpline","value":"1073","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."}]}