id":"ujiarpur-nityanand-rai","name":"Nityanand Rai","party":"Bharatiya Janata Party","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Shri%20Nityanand%20Rai%20taking%20charge%20as%20the%20Minister%20of%20State%20for%20Home%20Affairs%2C%20in%20New%20Delhi%20on%20June%2001%2C%202019.jpg?width=400","sub":"Ujiarpur"},{"id":"vaishali-veena-devi","name":"Veena Devi","party":"Ram Vilas","photo":"https://commons.wikimedia.org/wiki/Special:FilePath/Veena%20Devi%20Lok%20Sabha%20MP%20(cropped).jpg?width=400","sub":"Vaishali"}],"portal":{"url":"https://vaishali.nic.in","whosWhoUrl":"https://vaishali.nic.in/about-district/whos-who/","contactUrl":"https://vaishali.nic.in/contact-directory/","phone":"06224272501","retrieved":"2026-07-15"}}},"channels":[{"kind":"phone","topic":"grievance","label":"Bihar Lok Shikayat Nivaran - grievance toll-free helpline","value":"18003456284","scope":"state","source_url":"https://lokshikayat.bihar.gov.in/DefaultEn.aspx","source_name":"Bihar Lok Shikayat Nivaran (Bihar Public Grievance Redressal Rights Act portal), Government of Bihar","retrieved_date":"2026-07-15","note":"Official toll-free line to lodge a grievance or check its status under the Bihar Public Grievance Redressal Rights Act. Page states timings: daily 9:00 AM to 6:30 PM. This is Bihar's principal statewide citizen grievance helpline."},{"kind":"url","topic":"grievance","label":"Bihar Lok Shikayat Nivaran - online public grievance portal","value":"https://lokshikayat.bihar.gov.in/","scope":"state","source_url":"https://lokshikayat.bihar.gov.in/DefaultEn.aspx","source_name":"Bihar Lok Shikayat Nivaran portal, Government of Bihar","retrieved_date":"2026-07-15","note":"Bihar's statutory online grievance-redressal portal (file complaint, track status, two-level appeal). Verified live 2026-07-15."},{"kind":"phone","topic":"grievance","label":"Chief Minister Public Grievance Office, Patna","value":"06122205800","scope":"state","source_url":"https://patna.nic.in/helpline/","source_name":"District Patna, Government of Bihar (NIC) - Helpline page","retrieved_date":"2026-07-15","note":"Published as 'CHIEF MINISTER PUBLIC GRIEVANCE OFFICE' on the official NIC district helpline listing; the same number appears identically on madhubani.nic.in/helpline/. A landline, not a short-code helpline."},{"kind":"phone","topic":"general","label":"Jigyasa - Bihar government general information helpline","value":"06122233333","scope":"state","source_url":"https://patna.nic.in/helpline/","source_name":"District Patna, Government of Bihar (NIC) - Helpline page","retrieved_date":"2026-07-15","note":"Published as 'JIGYASA (FOR GENERAL INFORMATION)'. Same number appears identically on madhubani.nic.in/helpline/, and the Bihar state portal links a 'Jigyasa-Helpline' asset."},{"kind":"phone","topic":"corruption","label":"Vigilance helpline (Bihar)","value":"1800110180","scope":"state","source_url":"https://patna.nic.in/helpline/","source_name":"District Patna, Government of Bihar (NIC) - Helpline page","retrieved_date":"2026-07-15","note":"Published as 'VIGILANCE' on Bihar's official district helpline listing; same number appears identically on madhubani.nic.in/helpline/. Appears on the Bihar-specific list (alongside Bihar Krishak Aayog, Mahadalit Commission), not a generic national directory."},{"kind":"url","topic":"police","label":"Bihar Police - CCTNS Citizen Service Portal","value":"https://citizenservicesportal.bihar.gov.in/portal/","scope":"state","source_url":"https://citizenservicesportal.bihar.gov.in/portal/","source_name":"Bihar Citizen Service Portal (Bihar CCTNS), Bihar Police","retrieved_date":"2026-07-15","note":"Bihar Police's official citizen services portal: e-complaint, FIR copy, missing person/property reports, tenant/servant/driver and character verification, senior citizen registration. Page footer: '© 2025 | All Rights Reserved | Bihar Police'. Verified live 2026-07-15."},{"kind":"url","topic":"police","label":"Bihar Police - official website","value":"https://police.bihar.gov.in/","scope":"state","source_url":"https://police.bihar.gov.in/","source_name":"Bihar Police, Government of Bihar - official website","retrieved_date":"2026-07-15","note":"Official Bihar Police website (meta author: Government of Bihar). Note: it is a JavaScript single-page app that returns HTTP 200 for any path, so only the root URL is cited here."},{"kind":"url","topic":"general","label":"Government of Bihar - official state portal","value":"https://state.bihar.gov.in/main/CitizenHome.html","scope":"state","source_url":"https://state.bihar.gov.in/main/CitizenHome.html","source_name":"Government of Bihar - official state portal","retrieved_date":"2026-07-15","note":"Official state portal homepage (page title: 'Government of Bihar'). Verified live 2026-07-15. Requires cookies on first load."},{"kind":"url","topic":"general","label":"Districts of Bihar - district website directory","value":"https://state.bihar.gov.in/main/SectionInformation.html?editForm&rowId=19","scope":"state","source_url":"https://state.bihar.gov.in/main/SectionInformation.html?editForm&rowId=19","source_name":"Government of Bihar - official state portal, 'Districts of Bihar'","retrieved_date":"2026-07-15","note":"Official 'Districts of Bihar' directory on the state portal, linking each district's own website (Araria, Patna, Gaya, Muzaffarpur, West Champaran, etc. - all 38 districts). Verified: contains live links to araria.nic.in, patna.nic.in, gaya.nic.in, madhubani.nic.in and the rest."},{"kind":"url","topic":"women","label":"Bihar women helpline - district-wise contact directory","value":"https://wcdc.bihar.gov.in/Helpline","scope":"state","source_url":"https://wcdc.bihar.gov.in/Helpline","source_name":"Women & Child Development Corporation, Bihar","retrieved_date":"2026-07-15","note":"Official directory of women helpline centres across all 38 Bihar districts with local contacts, published by the state nodal agency."},{"kind":"phone","topic":"electricity","label":"Bihar electricity (BSPHCL / NBPDCL / SBPDCL) consumer complaint toll-free","value":"1912","scope":"state","source_url":"https://ccrs.bsphcl.co.in/","source_name":"Consumer Complaint Redressal System (CHS-Bihar), Bihar State Power Holding Company Ltd (BSPHCL)","retrieved_date":"2026-07-15","note":"Toll-free consumer complaint number published on the DISCOMs' own Consumer Complaint Redressal System. Same page also lists WhatsApp +91-9031683592, missed-call +91-9953101311 and SMS short code 5667700.","operator":"BSPHCL (NBPDCL / SBPDCL)"},{"kind":"url","topic":"electricity","label":"Bihar electricity - Consumer Complaint Redressal System (online)","value":"https://ccrs.bsphcl.co.in/","scope":"state","source_url":"https://ccrs.bsphcl.co.in/","source_name":"Consumer Complaint Redressal System (CHS-Bihar), BSPHCL","retrieved_date":"2026-07-15","note":"Centrally published online electricity complaint system covering both Bihar DISCOMs (NBPDCL and SBPDCL) under BSPHCL. Verified live 2026-07-15. Domain is the utility's own site (.co.in), not .gov.in.","operator":"BSPHCL (NBPDCL / SBPDCL)"},{"kind":"phone","topic":"emergency","label":"National Emergency Number (ERSS) - Police, Fire & Rescue, Health","value":"112","scope":"national","source_url":"https://www.mha.gov.in/en/commoncontent/emergency-response-support-system-erss","source_name":"Ministry of Home Affairs, Government of India","retrieved_date":"2026-07-15","note":"MHA's single pan-India emergency number: 'ONE INDIA ONE EMERGENCY NUMBER 112', a nationwide unified emergency response system. Works in every State/UT. Corroborated by india.gov.in helpline directory, which lists 112 as the Integrated Helpline (ERSS) covering Police, Fire & Rescue and Health services."},{"kind":"phone","topic":"fire","label":"Fire Helpline","value":"101","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed under 'Emergency Numbers' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"ambulance","label":"National Ambulance Service (NAS)","value":"102","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Ambulance Service (NAS)' under Emergency Numbers on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"women","label":"Women Helpline (national, toll-free)","value":"181","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Women Helpline Toll free No. - 181' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed on india.gov.in as both 'Women Helpline Number' and 'Domestic Violence Helpline'."},{"kind":"phone","topic":"women","label":"National Commission for Women (NCW) 24x7 Helpline","value":"14490","scope":"national","source_url":"https://ncw.gov.in/","source_name":"National Commission for Women (NCW)","retrieved_date":"2026-07-15","note":"NCW's own site states: 'Call the 24x7 NCW helpline at 14490 for immediate assistance and support', and lists 'NCW Women Helpline (14490)' under its Complaint Redressal cells. IMPORTANT: the india.gov.in helpline directory still lists 7827170170 as the 'National Commission for Women Helpline' - that number appears nowhere on ncw.gov.in (not even in raw HTML), so it appears stale and was deliberately omitted in favour of the department's own current number."},{"kind":"phone","topic":"child","label":"Child Helpline (national, toll-free)","value":"1098","scope":"national","source_url":"https://wcd.gov.in/","source_name":"Ministry of Women and Child Development, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Child Helpline Toll free No. - 1098' directly by the owning ministry (WCD) as a tel: link on its homepage. Also listed as 'Child Help Line' on india.gov.in."},{"kind":"phone","topic":"senior","label":"Elderline - National Helpline for Senior Citizens (NHSC)","value":"14567","scope":"national","source_url":"https://scw.dosje.gov.in/elderline","source_name":"Department of Social Justice & Empowerment, Government of India","retrieved_date":"2026-07-15","note":"Published as 'Elder Helpline: 14567' on the Department of Social Justice & Empowerment's own Elderline site, which the ministry homepage links to as the 'National Helpline for Senior Citizens (NHSC)'. india.gov.in additionally lists a landline 011-20893999 alongside 14567 for the Senior Citizens Helpline."},{"kind":"phone","topic":"grievance","label":"National Consumer Helpline (NCH)","value":"1915","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed as 'National Consumer Helpline (NCH)' on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026). Note: the NCH portal consumerhelpline.gov.in could not be reached at time of research (DNS resolves to an NIC address but the host refused connections / returned 504), so only the number is cited here - not the NCH portal URL."},{"kind":"phone","topic":"cyber","label":"Cyber Crime Helpline (online financial fraud reporting)","value":"1930","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Confirmed on the National Cyber Crime Reporting Portal homepage banner (MHA / Indian Cyber Crime Coordination Centre - I4C), which reads: 'To report online financial fraud, call 1930' and 'register your complaint at cybercrime.gov.in'. Independently corroborated by the india.gov.in helpline directory, which lists 1930 as the Cyber Crime Helpline."},{"kind":"url","topic":"cyber","label":"National Cyber Crime Reporting Portal (file a cybercrime complaint)","value":"https://cybercrime.gov.in/","scope":"national","source_url":"https://cybercrime.gov.in/","source_name":"National Cyber Crime Reporting Portal, MHA / I4C","retrieved_date":"2026-07-15","note":"Verified live. Ministry of Home Affairs portal for reporting cybercrime; supports anonymous reporting, women/children-related crime, financial fraud and other cybercrime, plus complaint tracking. Nationwide."},{"kind":"url","topic":"grievance","label":"CPGRAMS - Centralised Public Grievance Redress and Monitoring System","value":"https://pgportal.gov.in/","scope":"national","source_url":"https://pgportal.gov.in/","source_name":"Ministry of Personnel, Public Grievances & Pensions, Government of India","retrieved_date":"2026-07-15","note":"Verified live; this is the citizen-facing portal. The site states CPGRAMS is 'an online platform available to the citizens 24x7 to lodge their grievances to the public authorities on any subject related to service delivery... a single portal connected to all the Ministries/Departments of Government of India and States.' Supports tracking by registration ID and an appeal facility. Note: it does not cover RTI matters, subjudice/court matters, or religious matters."},{"kind":"url","topic":"corruption","label":"Central Vigilance Commission - lodge a corruption complaint","value":"https://portal.cvc.gov.in/","scope":"national","source_url":"https://portal.cvc.gov.in/","source_name":"Central Vigilance Commission (CVC), Government of India","retrieved_date":"2026-07-15","note":"Verified live. CVC's Complaint Management System with a 'Citizen Login', complaint status tracking and a published complaint handling policy. Linked from cvc.gov.in as 'Lodge a complaint'. Covers corruption complaints against central government organisations."},{"kind":"phone","topic":"disaster","label":"Relief Commissioner for Natural Calamities","value":"1070","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."},{"kind":"phone","topic":"road","label":"Road Accident Helpline","value":"1073","scope":"national","source_url":"https://www.india.gov.in/directory/helpline","source_name":"National Portal of India (india.gov.in), NIC / MeitY","retrieved_date":"2026-07-15","note":"Listed on the National Portal of India helpline directory (page last reviewed/updated 14 July 2026)."}]}